{
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Edit",
      "Write",
      "Bash(*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git push:*)",
      "Bash(git cherry-pick:*)",
      "Bash(ssh ramboq:*)",
      "Bash(chmod +x:*)",
      "Bash(pip install:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/ramanambore/projects/ramboq/.claude/hooks/post_edit_gate.sh",
            "async": true,
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/ramanambore/projects/ramboq/.claude/hooks/post_commit_ccwatch.sh",
            "async": true,
            "timeout": 60
          }
        ]
      }
    ]
  }
}
